# Example Environment Variables
# Copy this file to .env.local and fill in real values.

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# PostgreSQL
DATABASE_URL=postgres://username:password@host:5432/leg_tracker

# Optional first-run bootstrap (used by: bun run setup)
# Comma-separated Clerk user IDs for app_admins table
LEGTRACKER_INITIAL_ADMIN_USERS=

# Optional initial staff role seeding
# Comma-separated Clerk user IDs
LEGTRACKER_INITIAL_STAFF_USERS=
# One of: evaluator, chair, clerk
LEGTRACKER_INITIAL_STAFF_ROLE=evaluator
# Comma-separated chamber slugs (existing or seeded)
LEGTRACKER_INITIAL_STAFF_CHAMBERS=house-main,senate-main
